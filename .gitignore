# Minecraft modpack Git ignore rules

# Ignore OS/system files
.DS_Store
Thumbs.db

# Ignore Minecraft client/server cache
logs/
config/
saves/
crash-reports/
debug/
shaderpacks/
resourcepacks/
screenshots/

# Ignore extracted or backup packs
unzipped pack/
*.zip
*.rar

# Ignore IDE/project metadata
.idea/
.vscode/
*.iml

# Ignore server/world data
world/
run/
cache/
